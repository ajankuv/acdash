.DS_Store

# Python
.venv/
__pycache__/
*.py[cod]
*.pyo
.Python
.pytest_cache/

# Credentials and local config — NEVER commit these
.env
.env.*
*.env
/app/data/

# IDE / local tooling
.cursor/
.claude/

# Brainstorming / planning session artifacts (developer-local)
.superpowers/
docs/superpowers/

# Local ops notes (optional for contributors)
DASHBOARD.md

# R&D tree (decompile, probes, secrets) — not published. Only RND/.gitignore is tracked
# so collaborators know what to exclude if they keep a local RND/ directory.
RND/*
!RND/.gitignore

# Debug dump exports — contain account fields, device IDs, Wi‑Fi names
dumps/
*ac-infinity*dump*.json
*acdash*debug*.json
*.dump.json

# Local SQLite history + runtime data
*.db
*.sqlite
data/

# Logs and process files
*.log
*.pid

# Screenshot mockup source (PNG is committed, HTML source is not)
docs/assets/mockup.html

# Dev / QC scripts — useful locally but not part of the published app
tests/
app/qc_*.py
